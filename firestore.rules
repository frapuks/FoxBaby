rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Identifiant déterministe d'un couple (uids triés, joints par "_").
    function coupleId(a, b) {
      return a < b ? a + "_" + b : b + "_" + a;
    }
    // Vrai si les deux utilisateurs sont reliés par un couple existant.
    function areCoupled(a, b) {
      return exists(/databases/$(database)/documents/couples/$(coupleId(a, b)));
    }

    // Collection des prénoms : lecture pour les utilisateurs connectés,
    // écriture interdite depuis le client (seed via script/admin uniquement).
    match /names/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Données d'un utilisateur : accès réservé à son propriétaire.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Swipes : écriture par le propriétaire ; lecture par le propriétaire
      // OU par son partenaire de couple (pour calculer les matchs).
      match /swipes/{nameId} {
        allow write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null
          && (request.auth.uid == uid || areCoupled(request.auth.uid, uid));
      }
    }

    // Annuaire des codes de liaison : lisible par les connectés (pour résoudre
    // un code en compte), chaque utilisateur ne crée/modifie que son propre code.
    match /linkCodes/{code} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Couples : accessibles uniquement à leurs deux membres.
    match /couples/{id} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
    }

  }
}
